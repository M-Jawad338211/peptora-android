{
  "cli": { "version": ">= 3.0.0" },
  "build": {
    "development": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.peptora.io"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "ios": {},
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.peptora.io"
      }
    }
  }
}
